{
    "schemaVersion": 1,
    "id": "mod_id",
    "version": "${version}",
    "name": "${mod_name}",
    "description": "${description}",
    "authors": [
        "${mod_author}"
    ],
    "contact": {
        "homepage": "https://www.curseforge.com/members/reggarf/projects",
        "sources": "https://github.com/Reggarfgod/StoneVaults",
        "issues": "https://github.com/Reggarfgod/StoneVaults/issues",
        "discord": "https://discord.gg/JBFNW3wdTm"
    },
    "license": "${license}",
    "icon": "stonevault.png",
    "environment": "*",
    "entrypoints": {
        "main": [
          "com.reggarf.mods.StonevaultsFabric.StonevaultsFabric"
        ],
        "modmenu": [
            "com.reggarf.mods.StonevaultsFabric.config.MenuIntegration"
        ]
    },
    "mixins": [
        "stonevault.mixins.json",
        "stonevault.fabric.mixins.json"
    ],
    "depends": {
        "fabricloader": ">=${fabric_loader_version}",
        "fabric-api": "*",
        "minecraft": ">=${minecraft_version}",
        "java": ">=${java_version}",
        "cloth-config2": "*",
        "modmenu": "*",
        "better_lib": "*"
    },
    "suggests": {
        "another-mod": "*"
    }
}
  